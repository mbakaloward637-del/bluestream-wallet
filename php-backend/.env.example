APP_NAME=AbanRemit
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://abanremit.com

LOG_CHANNEL=stack
LOG_LEVEL=info
LOG_FILE=./storage/logs/laravel.log

# ─── Database (MySQL) ───
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=abancool_aban
DB_USERNAME=abancool_labo
DB_PASSWORD=

# ─── Queue ───
QUEUE_CONNECTION=database

# ─── JWT Authentication ───
JWT_SECRET=
JWT_TTL=1440

# ─── Frontend (CORS) ───
FRONTEND_URL=https://abanremit.com,https://www.abanremit.com
VITE_API_BASE_URL=https://abanremit.com/api

# ─── M-Pesa (Safaricom Daraja - PRODUCTION) ───
MPESA_API_URL=https://api.safaricom.co.ke
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=000772
MPESA_PASSKEY=
MPESA_INITIATOR_NAME=apiuser
MPESA_SECURITY_CREDENTIAL=
MPESA_CALLBACK_ALLOWED_IPS=41.90.115.0,41.223.34.0
MPESA_VALIDATION_URL=https://abanremit.com/api/v1/webhooks/mpesa/validation
MPESA_CONFIRMATION_URL=https://abanremit.com/api/v1/webhooks/mpesa/c2b
MPESA_B2C_RESULT_URL=https://abanremit.com/api/v1/webhooks/mpesa/b2c
MPESA_B2C_TIMEOUT_URL=https://abanremit.com/api/v1/webhooks/mpesa/b2c
MPESA_ENV=production

# ─── Paystack (PRODUCTION) ───
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_CALLBACK_URL=https://abanremit.com/api/v1/webhooks/paystack

# ─── Airtime - Instalipa (PRODUCTION) ───
INSTALIPA_API_URL=https://api.instalipa.com
INSTALIPA_CONSUMER_KEY=
INSTALIPA_CONSUMER_SECRET=
INSTALIPA_CALLBACK_URL=https://abanremit.com/api/v1/webhooks/airtime
INSTALIPA_TIMEOUT=30000

# ─── SMS - TalkSasa (PRODUCTION) ───
TALKSASA_API_URL=https://bulksms.talksasa.com/api/v3
TALKSASA_API_TOKEN=
TALKSASA_SENDER_ID=ABANREMIT
TALKSASA_TIMEOUT=15000

# ─── Exchange Rates API ───
EXCHANGE_RATE_API_URL=https://v6.exchangerate-api.com/v6
EXCHANGE_RATE_API_KEY=

# ─── Security ───
BCRYPT_ROUNDS=12
PIN_MAX_ATTEMPTS=3
PIN_LOCK_DURATION_MINUTES=15
OTP_EXPIRY_MINUTES=10

# ─── File Uploads ───
MAX_FILE_SIZE_MB=5
UPLOAD_DIR=./uploads
ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf
FILESYSTEM_DISK=local

# ─── Redis (optional) ───
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Mail (SMTP) ───
MAIL_MAILER=smtp
MAIL_HOST=mail.abanremit.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=support@abanremit.com
MAIL_FROM_NAME="ABANREMIT Support"

# ─── Rate Limiting ───
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

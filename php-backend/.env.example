APP_NAME=AbanRemit
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-api-domain.com

# Frontend URL (for CORS)
FRONTEND_URL=https://your-frontend-domain.com

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=abanremit
DB_USERNAME=root
DB_PASSWORD=

JWT_SECRET=
JWT_TTL=1440

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=

# ─── Paystack ───
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# ─── M-Pesa (Safaricom Daraja API) ───
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_INITIATOR_NAME=apiuser
MPESA_SECURITY_CREDENTIAL=
MPESA_CALLBACK_URL=https://your-api-domain.com/api/v1/webhooks/mpesa/c2b
MPESA_B2C_RESULT_URL=https://your-api-domain.com/api/v1/webhooks/mpesa/b2c
MPESA_B2C_TIMEOUT_URL=https://your-api-domain.com/api/v1/webhooks/mpesa/b2c
MPESA_ENV=sandbox

# ─── Africa's Talking (SMS + Airtime) ───
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=
AT_ENV=sandbox

# File Storage
FILESYSTEM_DISK=local
